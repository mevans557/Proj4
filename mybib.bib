@incollection{keeling17MetapopulationDynamics2004,
  title = {17 - {{Metapopulation Dynamics}} of {{Infectious Diseases}}},
  booktitle = {Ecology, {{Genetics}} and {{Evolution}} of {{Metapopulations}}},
